# ─────────────────────────────────────────────────────────────
# PostgreSQL Superuser (used by the postgres container)
# ─────────────────────────────────────────────────────────────
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASSWORD=postgres_root_pass

# ─────────────────────────────────────────────────────────────
# Application DB User (created by postgres-init.sql)
# ─────────────────────────────────────────────────────────────
DB_USER=brd_user
DB_PASSWORD=Brd@Secure2024!

